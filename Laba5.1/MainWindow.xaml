<Window x:Class="Laba5._1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Horse Race"
        Height="700"
        Width="1200"
        MinHeight="500">

    <Grid Background="LightGray">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0"
                    Grid.Column="0"
                    Margin="10">

            <TextBlock Text="Settings"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0 0 0 20"/>

            <TextBlock Text="Кількість коней:"/>

            <ListBox x:Name="HorseCountListBox"
                     Height="100"
                     Margin="0 10 0 20"
                     SelectionChanged="HorseCountListBox_SelectionChanged">
                
                <ListBoxItem Content="2"/>
                <ListBoxItem Content="3"/>
                <ListBoxItem Content="4"/>
                <ListBoxItem Content="5"/>
                <ListBoxItem Content="6"/>
                <ListBoxItem Content="7"/>
                <ListBoxItem Content="8"/>

            </ListBox>

            <Button x:Name="StartButton"
                    Content="СТАРТ"
                    Height="40"
                    Click="StartButton_Click"/>

        </StackPanel>

        <Border 
            Grid.Row="0"
            Grid.Column="1"
            Margin="10"
            BorderThickness="3"
            BorderBrush="Black"
            Background="ForestGreen">

            <ScrollViewer x:Name="RaceScrollViewer" 
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled">
                <Canvas x:Name="RaceCanvas"
                    Width="950"
                    Height="{Binding ActualHeight, ElementName=RaceScrollViewer, Mode=OneWay}">

                    <!-- Додаємо лінію фінішу -->
                    <Rectangle x:Name="FinishLine" 
                               Width="5" 
                               Fill="Yellow" 
                               Opacity="0.8"/>
                </Canvas>
            </ScrollViewer>
        </Border>

        <DataGrid Grid.Row="1"
          Grid.ColumnSpan="2"
          Margin="10"
          AutoGenerateColumns="False"
          ItemsSource="{Binding Horses}">
           

            <DataGrid.Columns>

                <DataGridTextColumn Header="Ім'я"
                                    Binding="{Binding Name}"/>
                <DataGridTextColumn Header="Позиція" 
                                    Binding="{Binding Position}"/>
                <DataGridTextColumn Header="Час"
                                    Binding="{Binding FinishTime}"/>


            </DataGrid.Columns>

        </DataGrid>

    </Grid>
    
</Window>